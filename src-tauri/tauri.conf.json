{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chinese Chess",
  "version": "0.2.0",
  "identifier": "com.local.chinesechess",
  "build": {
    "beforeDevCommand": "npm run tauri:sync",
    "beforeBuildCommand": "npm run tauri:sync",
    "frontendDist": "../tauri-web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "中国象棋",
        "width": 1440,
        "height": 940,
        "minWidth": 1260,
        "minHeight": 780,
        "resizable": true,
        "backgroundColor": "#17201d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../engines/*"
    ],
    "category": "Game"
  }
}
